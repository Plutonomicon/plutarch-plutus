eq (\i-0 -> equalsString i-0 i-0) "foo"
semigroup.laws.id.1 (\i-0 -> equalsString (appendString "" i-0) i-0) "foo"
semigroup.laws.id.2 (\i-0 -> equalsString i-0 (appendString "" i-0)) "foo"
semigroup.concat equalsString (appendString "foo" "bar") "foobar"
semigroup.mempty (\i-0 -> equalsString i-0 i-0) ""
