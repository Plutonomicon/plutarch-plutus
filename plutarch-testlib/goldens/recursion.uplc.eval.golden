iterateN.lam \i-0 i-1 i-2 ->
  case
    (equalsInteger i-0 0)
    [ (case
         (constr 0 [(subtractInteger i-0 1), i-1, (i-1 i-2)])
         [ (\i-3 ->
              (\i-4 ->
                 (\i-5 i-6 i-7 i-8 ->
                    case
                      (equalsInteger i-6 0)
                      [ (case
                           (constr 0 [(subtractInteger i-6 1), i-7, (i-7 i-8)])
                           [i-5])
                      , i-8 ])
                   (\i-9 -> i-4 i-4 i-9))
                (\i-10 ->
                   (\i-11 i-12 i-13 i-14 ->
                      case
                        (equalsInteger i-12 0)
                        [ (case
                             (constr 0
                                [(subtractInteger i-12 1), i-13, (i-13 i-14)])
                             [i-11])
                        , i-14 ])
                     (\i-15 -> i-10 i-10 i-15))
                i-3) ])
    , i-2 ]
iterateN.app.succ 10
iterateN.app.double 1024
